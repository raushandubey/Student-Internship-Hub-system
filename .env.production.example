# Production Environment Configuration for S3 Resume Display
# Copy this file to .env in production and update with actual values

APP_NAME="Student Internship Hub"
APP_ENV=production
APP_KEY=base64:your_production_key_here
APP_DEBUG=false
APP_URL=https://your-production-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=your_production_db_host
DB_PORT=3306
DB_DATABASE=your_production_database
DB_USERNAME=your_production_db_user
DB_PASSWORD=your_production_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

# AWS S3 Configuration - REQUIRED for production
# These values MUST be configured for S3 resume display to work
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your_s3_bucket_name_here
AWS_URL=https://your_s3_bucket_name_here.s3.amazonaws.com
AWS_ENDPOINT=https://your_laravel_cloud_endpoint_here
AWS_USE_PATH_STYLE_ENDPOINT=false

CACHE_STORE=redis
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_HOST=your_mail_host
MAIL_PORT=587
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
