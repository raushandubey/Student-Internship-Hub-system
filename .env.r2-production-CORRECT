APP_NAME="Student Internship Hub"
APP_ENV=production
APP_KEY=base64:your_production_key_here
APP_DEBUG=false
APP_URL=https://your-laravel-cloud-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=your_production_db_host
DB_PORT=3306
DB_DATABASE=your_production_database
DB_USERNAME=your_production_db_user
DB_PASSWORD=your_production_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

# ============================================================================
# CLOUDFLARE R2 CONFIGURATION - CRITICAL FOR RESUME ACCESS
# ============================================================================
# 
# ARCHITECTURE OVERVIEW:
# ----------------------
# Cloudflare R2 provides TWO different URLs:
#
# 1. R2 ENDPOINT (AWS_ENDPOINT):
#    - Purpose: API operations (upload, delete, list files)
#    - Used by: Laravel Storage facade for file operations
#    - Format: https://{account_id}.r2.cloudflarestorage.com
#    - Public Access: NO - requires authentication
#    - Example: https://abc123def456.r2.cloudflarestorage.com
#
# 2. R2 PUBLIC BUCKET URL (AWS_URL):
#    - Purpose: Public file access (view, download)
#    - Used by: Browser to load files directly
#    - Format: https://pub-{hash}.r2.dev
#    - Public Access: YES - no authentication required
#    - Example: https://pub-1234567890abcdef.r2.dev
#
# CRITICAL DISTINCTION:
# --------------------
# AWS_ENDPOINT = For Laravel to upload/delete files (API operations)
# AWS_URL = For browsers to view files (public access)
#
# COMMON MISTAKE (causes ERR_TOO_MANY_REDIRECTS):
# -----------------------------------------------
# ❌ WRONG: AWS_URL=https://your-laravel-cloud-domain.com
#    Result: Browser requests Laravel → Redirect loop → ERR_TOO_MANY_REDIRECTS
#
# ✅ CORRECT: AWS_URL=https://pub-{hash}.r2.dev
#    Result: Browser requests R2 directly → PDF opens instantly
#
# ============================================================================

# R2 Access Credentials (from Cloudflare R2 API Tokens)
# ------------------------------------------------------
# How to get:
# 1. Go to Cloudflare Dashboard → R2 → Manage R2 API Tokens
# 2. Click "Create API Token"
# 3. Name: "Laravel Production"
# 4. Permissions: "Object Read & Write"
# 5. Select your bucket
# 6. Copy Access Key ID and Secret Access Key

AWS_ACCESS_KEY_ID=your_r2_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# R2 Region (MUST be 'auto' for Cloudflare R2)
# ---------------------------------------------
# ❌ WRONG: AWS_DEFAULT_REGION=us-east-1 (AWS regions don't apply to R2)
# ✅ CORRECT: AWS_DEFAULT_REGION=auto (R2 requires 'auto')

AWS_DEFAULT_REGION=auto

# R2 Bucket Name
# --------------
# Your bucket name from Cloudflare R2

AWS_BUCKET=your-bucket-name

# ============================================================================
# CRITICAL: AWS_URL - R2 PUBLIC BUCKET URL
# ============================================================================
# This is the MOST IMPORTANT setting for fixing ERR_TOO_MANY_REDIRECTS
#
# HOW TO GET YOUR R2 PUBLIC BUCKET URL:
# --------------------------------------
# 1. Go to Cloudflare Dashboard: https://dash.cloudflare.com/
# 2. Click "R2" in left sidebar
# 3. Click your bucket name
# 4. Click "Settings" tab
# 5. Scroll to "Public access" section
# 6. If disabled, click "Allow Access" button
# 7. Copy the "Public bucket URL" that appears
#    Format: https://pub-{hash}.r2.dev
#    Example: https://pub-1234567890abcdef.r2.dev
#
# PASTE YOUR R2 PUBLIC BUCKET URL HERE:
# --------------------------------------
# ❌ DO NOT use your Laravel Cloud domain
# ❌ DO NOT use the R2 endpoint URL
# ✅ USE the R2 public bucket URL (pub-{hash}.r2.dev)

AWS_URL=https://pub-YOUR-HASH-HERE.r2.dev

# ============================================================================
# AWS_ENDPOINT - R2 API ENDPOINT
# ============================================================================
# This is for API operations (upload/delete) - NOT for browser access
#
# HOW TO GET YOUR R2 ENDPOINT:
# ----------------------------
# 1. Go to Cloudflare Dashboard
# 2. Look at URL: https://dash.cloudflare.com/{account_id}/r2
# 3. Copy the {account_id} from URL
# 4. Your endpoint: https://{account_id}.r2.cloudflarestorage.com
#
# PASTE YOUR R2 ENDPOINT HERE:
# ----------------------------
# Format: https://{account_id}.r2.cloudflarestorage.com
# Example: https://abc123def456.r2.cloudflarestorage.com

AWS_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ============================================================================
# AWS_USE_PATH_STYLE_ENDPOINT - MUST BE TRUE FOR R2
# ============================================================================
# Cloudflare R2 requires path-style endpoints
# ❌ WRONG: AWS_USE_PATH_STYLE_ENDPOINT=false (causes connection errors)
# ✅ CORRECT: AWS_USE_PATH_STYLE_ENDPOINT=true (required for R2)

AWS_USE_PATH_STYLE_ENDPOINT=true

# ============================================================================
# CONFIGURATION VERIFICATION CHECKLIST
# ============================================================================
#
# ✓ FILESYSTEM_DISK=s3 (use S3 driver for R2)
# ✓ AWS_DEFAULT_REGION=auto (R2 requires 'auto', not AWS regions)
# ✓ AWS_USE_PATH_STYLE_ENDPOINT=true (R2 requires path-style)
# ✓ AWS_URL=https://pub-{hash}.r2.dev (PUBLIC bucket URL, NOT Laravel domain)
# ✓ AWS_ENDPOINT=https://{account_id}.r2.cloudflarestorage.com (API endpoint)
# ✓ Bucket has public access enabled in Cloudflare R2 settings
# ✓ CORS configured for your domain (if using iframe/browser access)
#
# ============================================================================
# URL GENERATION FLOW
# ============================================================================
#
# When Laravel generates a resume URL:
# 1. Profile::getResumeUrl() calls Storage::disk('s3')->url($path)
# 2. Laravel reads AWS_URL from config
# 3. Returns: AWS_URL + '/' + $path
# 4. Example: https://pub-{hash}.r2.dev/resumes/filename.pdf
# 5. Browser requests this URL directly from R2 (not Laravel)
# 6. R2 serves the file with public access (no authentication)
# 7. PDF opens instantly (zero redirects)
#
# ============================================================================
# CORS CONFIGURATION (Optional - for iframe/browser access)
# ============================================================================
#
# If you need CORS for iframe embedding or browser access:
# 1. Go to Cloudflare R2 → Your Bucket → Settings → CORS policy
# 2. Add this configuration:
#
# [
#   {
#     "AllowedOrigins": ["https://your-laravel-cloud-domain.com"],
#     "AllowedMethods": ["GET", "HEAD"],
#     "AllowedHeaders": ["*"],
#     "ExposeHeaders": ["ETag"],
#     "MaxAgeSeconds": 3000
#   }
# ]
#
# ============================================================================

CACHE_STORE=redis
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_HOST=your_mail_host
MAIL_PORT=587
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

