APP_NAME="Student Internship Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

# Server Configuration
OCTANE_ENABLED=false

# Filesystem Configuration
# Default storage disk for file uploads (s3 for production, public for local development)
FILESYSTEM_DISK=s3

# AWS S3 Configuration
# Laravel Cloud auto-populates these credentials when S3 storage is attached
# For local development, obtain these from AWS IAM Console or use LocalStack

# AWS access key ID for S3 authentication
AWS_ACCESS_KEY_ID=

# AWS secret access key for S3 authentication
AWS_SECRET_ACCESS_KEY=

# AWS region where your S3 bucket is located (e.g., us-east-1, eu-west-1)
AWS_DEFAULT_REGION=us-east-1

# S3 bucket name for file storage
AWS_BUCKET=

# Optional: Custom S3 URL (useful for CloudFront CDN or custom domains)
AWS_URL=

# Optional: Custom S3 endpoint (useful for LocalStack or S3-compatible services)
AWS_ENDPOINT=

# Use path-style endpoint format (required for LocalStack, false for AWS S3)
AWS_USE_PATH_STYLE_ENDPOINT=false

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_LEVEL=error

MAIL_MAILER=log

OPENAI_API_KEY=
